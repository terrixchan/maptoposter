.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.input {
  border: 2rpx solid #d1d5db;
  border-radius: 10rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 16rpx;
  background: #fff;
}

.btn {
  background: #0f766e;
  color: #fff;
  border-radius: 10rpx;
  font-size: 30rpx;
}

.btn.secondary {
  margin-top: 20rpx;
  background: #1d4ed8;
}

.result {
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.poster {
  width: 100%;
  border-radius: 12rpx;
}
